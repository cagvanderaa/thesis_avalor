<launch>
    <!-- Include the multi-UAV MAVROS SITL launch file from offboard_py package -->
    <include file="$(find offboard_py)/launch/multi_uav_mavros_sitl.launch"/>

    <!-- Target drone node -->
    <node name="target_node" pkg="offboard_py" type="target.py" output="screen"/>

    <!-- Pursuer drone node -->
    <node name="pursuer_node" pkg="offboard_py" type="pursuer.py" output="screen"/>

    <!-- Analysis node -->
    <node name="error_logger_node" pkg="offboard_py" type="analysis.py" output="screen"/>
</launch>
